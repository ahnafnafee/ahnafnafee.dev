NEXT_PUBLIC_TWITTER_USERNAME=@twitter username
NEXT_PUBLIC_SITE_NAME=site name
NEXT_PUBLIC_SITE_URL=site url including "https://"

# Read-count storage. Provisioned via Vercel Marketplace → Neon Postgres.
# `vercel env pull` will populate this locally once the integration is linked.
# Leaving it unset is safe — the pageview API gracefully returns 0 and no
# build-time dependency on Neon kicks in.
DATABASE_URL=postgres://user:pass@host/db?sslmode=require
